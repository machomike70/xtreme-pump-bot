# ============================================================
# Xtreme Pump Bot — Production Environment
# Copy this file to .env and fill in the three CHANGE_ME values.
# ============================================================

# PostgreSQL connection string (Hetzner)
# e.g. postgres://pumpbot:your-password@91.98.121.41:5432/pumpbot
DATABASE_URL=postgres://CHANGE_ME:CHANGE_ME@91.98.121.41:5432/pumpbot

# Server
PORT=8080
NODE_ENV=production
LOG_LEVEL=info
APP_DOMAIN=pump.xtremerippleprotocol.online

# Telegram Bot (Xtreme_Pump_Bot)
# Full token from BotFather — starts with 7818413149:
PUMP_ALPHA_BOT_TOKEN=7818413149:CHANGE_ME

# Telegram channel(s) to broadcast launches to
# Comma-separated negative chat IDs, e.g. -1001234567890,-1009876543210
PUMP_ALPHA_CHAT_IDS=CHANGE_ME

# Webhook secret — generate with: openssl rand -hex 32
# A ready-made value: 66a1423ea029d9ff35c9f0cb224bf4a92ecfbb4226decd83
PUMP_ALPHA_WEBHOOK_SECRET=your-webhook-secret-here
